# Claude API key — required. Get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pick a model. Leave blank for the SDK default.
#   claude-haiku-4-5       → fastest + cheapest
#   claude-sonnet-4-6      → balanced (good default)
#   claude-opus-4-7        → best reasoning, most expensive
ANTHROPIC_MODEL=claude-sonnet-4-6

# Repos the agent explores. Defaults point at the public Memgraph org; override
# to point at a fork or a different branch.
MEMGRAPH_REPO_URL=https://github.com/memgraph/memgraph.git
MEMGRAPH_REPO_BRANCH=master
HELM_CHARTS_REPO_URL=https://github.com/memgraph/helm-charts.git
HELM_CHARTS_REPO_BRANCH=main
AI_TOOLKIT_REPO_URL=https://github.com/memgraph/ai-toolkit.git
AI_TOOLKIT_REPO_BRANCH=main

# Optional: change the port the backend binds to
PORT=8001
